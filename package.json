{
  "name": "omit-deep-ts",
  "version": "1.0.0",
  "description": "Drop-in Typescript replacement for omit-deep-lodash with no dependencies",
  "keywords": [
    "omit",
    "deep",
    "lodash",
    "typescript",
    "object"
  ],
  "homepage": "https://github.com/alpolinar/omit-deep-ts#readme",
  "bugs": {
    "url": "https://github.com/alpolinar/omit-deep-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alpolinar/omit-deep-ts.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.0"
  },
  "license": "MIT",
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0",
  "author": "Al Polinar",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^24.12.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
